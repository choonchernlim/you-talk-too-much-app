# GCP Vertex AI
GCP_VERTEX_PROJECT=your-project-id
GCP_VERTEX_LOCATION=us-central1
GCP_VERTEX_SA_KEY=/path/to/your/service-account-key.json
GCP_VERTEX_MODEL=gemini-2.5-flash

# Microsoft / OneNote
ONENOTE_SECTION_NAME=Meetings
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id

# HuggingFace Models
HF_WHISPER_MODEL=mlx-community/whisper-large-v3-mlx
HF_DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
HF_EMBEDDING_MODEL=pyannote/embedding
HF_TOKEN=your-huggingface-token
